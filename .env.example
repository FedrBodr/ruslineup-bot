# Telegram
BOT_TOKEN=123456:put-your-botfather-token-here
ADMIN_CHAT_ID=000000000          # твой Telegram ID для уведомлений о заявках

# PostgreSQL (этап 2) — source of truth.
# Вариант А: одна строка
DATABASE_URL=postgresql://user:pass@host:5432/ruslineup
# Вариант Б: по компонентам (если DATABASE_URL пуст — собирается из них; Amvera отдаёт так)
# DATABASE_HOST=
# DATABASE_PORT=5432
# DATABASE_USER=
# DATABASE_PASSWORD=
# DATABASE_NAME=ruslineup

# AI-фолбэк (этап 6)
LLM_API_KEY=
LLM_MODEL=

# Промокоды (этап 5)
PARTNER_NICK=@partner_nick
PARTNER_DISCOUNT=                # размер скидки у партнёра, напр. "−5%"

# Чувствительные данные — ТОЛЬКО здесь/в переменных Amvera, НЕ в коде и не в knowledge.md
# (репозиторий публичный). Цены/условия меняются — держим в ENV.
# Доски / электросёрф (этап 3 — FAQ)
BOARD_12KW=                      # цена доски 12 кВт, напр. "от 310 000 ₽"
BOARD_14KW=                      # цена доски 14 кВт, напр. "от 380 000 ₽"
SEAT_KIT=                        # комплект с сиденьем, напр. "от 60 000 ₽"
BATTERY_1=                       # доп. батарея 50–70 мин
BATTERY_2=                       # доп. батарея 60–80 мин
PREORDER_TERMS=                  # условия предзаказа, напр. "Предоплата 100%"

# Тест-день (этап 4). В v1 пусто → бот говорит «уточняйте у менеджера»
TESTDAY_PRICE=
