# Telegram
BOT_TOKEN=123456:put-your-botfather-token-here
ADMIN_CHAT_ID=000000000          # твой Telegram ID для уведомлений о заявках

# Google Sheets (этап 2)
SHEET_ID=put-google-sheet-id-here
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json

# AI-фолбэк (этап 6)
LLM_API_KEY=
LLM_MODEL=

# Промокоды
PARTNER_NICK=@partner_nick

# Чувствительные данные — ТОЛЬКО здесь/в переменных Amvera, НЕ в коде и не в knowledge.md
# (репозиторий публичный). Цены/условия меняются — держим в ENV.
BOARD_PRICE=                     # цена доски, напр. "от 120 000 ₽"
PREORDER_TERMS=                  # условия предзаказа
TESTDAY_PRICE=                   # стоимость тест-дня
PARTNER_DISCOUNT=                # размер/условие скидки у партнёра
